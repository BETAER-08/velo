{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velo",
  "version": "0.1.0-beta",
  "identifier": "com.betaer.velo",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ui && pnpm dev",
    "beforeBuildCommand": "cd ui && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Velo",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
